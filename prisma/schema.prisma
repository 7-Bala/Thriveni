generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Car {
  id           String   @id @default(uuid())
  brand        String
  model        String
  variant      String
  type         String
  price        Float
  fuel         String
  transmission String
  year         Int
  mileage      Float
  color        String
  images       String
  features     String
  specs        String
  isNew        Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  isAvailable  Boolean  @default(true)
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Lead {
  id          String   @id @default(uuid())
  name        String
  phone       String
  email       String?
  carInterest String?
  branch      String?
  message     String?
  source      String   @default("website")
  queryType   String   @default("GENERAL")
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  address   String
  phone     String
  whatsapp  String
  email     String?
  mapUrl    String
  embedUrl  String?
  lat       Float
  lng       Float
  brands    String
  isActive  Boolean  @default(true)
  openTime  String
  closeTime String
  cars      Car[]
}

model Testimonial {
  id           String   @id @default(uuid())
  name         String
  location     String
  carPurchased String
  rating       Float
  review     String
  videoUrl     String?
  imageUrl     String?
  isVerified   Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String?
  subject   String
  branch    String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
